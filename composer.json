{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "themarketer/api-client",
  "description": "The Marketer PHP api client",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.0",
    "ext-mbstring": "*",
    "laravel/framework": "^10.50",
    "spatie/laravel-data": "^4.20",
    "spatie/php-structure-discoverer": "~2.2.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "orchestra/testbench": "^8.37"
  },
  "autoload": {
    "psr-4": {
      "TheMarketer\\ApiClient\\": "src/",
      "NotificationService\\Sdk\\Internal\\": "src/Api/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
