{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "themarketer/api-client",
  "description": "The Marketer PHP api client",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.0",
    "ext-mbstring": "*",
    "symfony/validator": "^7.0",
    "symfony/expression-language": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "orchestra/testbench": "^8.37"
  },
  "autoload": {
    "psr-4": {
      "TheMarketer\\ApiClient\\": "src/",
      "NotificationService\\Sdk\\Internal\\": "src/Api/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "aliases": {
        "TheMarketer": "TheMarketer\\ApiClient\\Laravel\\Facades\\TheMarketer"
      },
      "providers": [
        "TheMarketer\\ApiClient\\Laravel\\ApiClientServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
